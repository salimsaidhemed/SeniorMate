# SeniorMate local development example
# Copy this file to .env and replace placeholders with local-only values.

APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-local-only
CORS_ORIGINS=http://localhost:5173

BACKEND_HOST=127.0.0.1
BACKEND_PORT=5001
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:5001/api
VITE_AUTH_ENABLED=false
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=seniormate
VITE_KEYCLOAK_CLIENT_ID=seniormate-frontend
VITE_KEYCLOAK_API_CLIENT_ID=seniormate-api

DATABASE_URL=postgresql+psycopg://seniormate:change-me-local-only@postgres:5432/seniormate
POSTGRES_DB=seniormate
POSTGRES_USER=seniormate
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432

AUTH_ENABLED=false
KEYCLOAK_ISSUER=http://localhost:8080/realms/seniormate
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/seniormate/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=seniormate-api
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=seniormate
KEYCLOAK_ADMIN_CLIENT_ID=seniormate-admin-api
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-local-only
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-local-only
KEYCLOAK_PORT=8080

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=local-access-key
MINIO_SECRET_KEY=change-me-local-only
MINIO_BUCKET=seniormate-medical-records
MINIO_SECURE=false
MEDICAL_RECORD_MAX_FILE_SIZE=10485760
PATIENT_PHOTO_MAX_FILE_SIZE=5242880
BRANDING_LOGO_MAX_FILE_SIZE=2097152
MINIO_ROOT_USER=local-access-key
MINIO_ROOT_PASSWORD=change-me-local-only
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
