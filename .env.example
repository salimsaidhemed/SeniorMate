# SeniorMate local development example
# Copy this file to .env and replace placeholders with local-only values.

APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-local-only

BACKEND_HOST=127.0.0.1
BACKEND_PORT=5000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173

DATABASE_URL=postgresql://seniormate:seniormate@localhost:5432/seniormate
POSTGRES_DB=seniormate
POSTGRES_USER=seniormate
POSTGRES_PASSWORD=change-me-local-only

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=seniormate
KEYCLOAK_CLIENT_ID=seniormate-local
KEYCLOAK_CLIENT_SECRET=change-me-local-only

MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=seniormate-local
MINIO_ACCESS_KEY=local-access-key
MINIO_SECRET_KEY=change-me-local-only
